{
  "name": "@xianlee/godot-mcp",
  "version": "0.2.2",
  "description": "MCP server for Godot Engine — zero-config auto-detection, semantic search, visual diff UI, and full editor integration.",
  "type": "module",
  "bin": {
    "godot-mcp": "./server/dist/index.js"
  },
  "files": [
    "server/dist",
    "server/scripts",
    "addons"
  ],
  "scripts": {
    "build": "cd server && npm run build",
    "prepare": "npm run build",
    "start": "node server/dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector server/dist/index.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "fastmcp": "^1.27.7",
    "sqlite-vec": "^0.1.7-alpha.2",
    "sqlite3": "^5.1.7",
    "websocket": "^1.0.35",
    "ws": "^8.13.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/6NineLives/godot-mcp.git"
  },
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "claude",
    "cline",
    "fastmcp",
    "game-engine"
  ]
}
